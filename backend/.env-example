# ============================================================
# CDP Webapp Backend Environment Variables
# ============================================================

# ============================================================
# Google Cloud Configuration
# ============================================================
# Google Cloud Project ID
# Get from: https://console.cloud.google.com/
PROJECT_ID=

# Google Cloud region/location
# Example: us-central1
LOCATION=

# ============================================================
# Application Environment
# ============================================================
# Options: development, production, test
APP_ENV=development

# Debug mode
DEBUG=true

# Shared API key required on /api/v1 requests
API_KEY=

# Header name used for the shared API key
API_KEY_HEADER_NAME=X-API-Key

# Project metadata
PROJECT_NAME=CDP Webapp
VERSION=1.0.0
DESCRIPTION=CDP climate data platform webapp

# ============================================================
# LLM Configuration
# ============================================================
# API key for LLM service (can be same as GOOGLE_API_KEY for Gemini)
LLM_API_KEY=

# Model to use for LLM calls
LLM_MODEL=gemini-3-flash-preview

# Temperature for LLM generation (0.0-1.0)
DEFAULT_LLM_TEMPERATURE=0.2

# Maximum tokens in LLM response
MAX_TOKENS=2000

# Maximum tokens accepted from chat clients
MAX_CHAT_MAX_TOKENS=2000

# Maximum number of chat messages accepted in one request
MAX_CHAT_MESSAGES=50

# Maximum combined size of all chat message bodies
MAX_CHAT_TOTAL_CHARS=50000

# Number of retries for failed LLM calls
MAX_LLM_CALL_RETRIES=3

# ============================================================
# Database Configuration (PostgreSQL)
# ============================================================
# Database name
POSTGRES_DB=cdp

# Database user
POSTGRES_USER=postgres

# Database password
POSTGRES_PASSWORD=

# Database host
POSTGRES_HOST=localhost

# Database port
POSTGRES_PORT=5432

# Connection pool size
POSTGRES_POOL_SIZE=20

# Connection pool max overflow
POSTGRES_MAX_OVERFLOW=10

# Langfuse Configuration (LLM Observability)
# Optional: https://langfuse.com/docs/get-started
# ============================================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================
# CORS Configuration
# ============================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:4201,http://localhost:4200

# ============================================================
# Logging Configuration
# ============================================================
# Directory for log files
LOG_DIR=../logs

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Log format: json or console
LOG_FORMAT=console

# ============================================================
# Rate Limiting (per user)
# ============================================================
# Default rate limits (comma-separated)
RATE_LIMIT_DEFAULT=1000 per day,200 per hour

# Endpoint-specific rate limits
RATE_LIMIT_CHAT=10 per minute
RATE_LIMIT_SUGGEST_FOLLOW_UPS=10 per minute
RATE_LIMIT_TRANSLATE=60 per minute

# ============================================================
# External Service Configuration
# ============================================================
# Base URL for discloser profile service used for organization geometry lookup
DISCLOSER_SERVICE_BASE_URL=https://discloser-profile-service-pbybuiwoxq-uc.a.run.app

# ============================================================
# Evaluation Configuration (Optional)
# For testing LLM outputs with external evaluator
# ============================================================
EVALUATION_LLM=gpt-4o-mini
EVALUATION_BASE_URL=https://api.openai.com/v1
EVALUATION_API_KEY=
EVALUATION_SLEEP_TIME=10
