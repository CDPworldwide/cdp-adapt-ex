#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage:
  script/run-test-question <account-id> "<question>"

Examples:
  script/run-test-question 831391 "has the city ranked the hazards in their disclosure?"

Environment:
  AI_SERVER_HOST        Host for local services. Default: 127.0.0.1
  AI_SERVER_PORT        Port for the temporary AI server. Default: first free port
  LOCATION_STUB_PORT    Port for the temporary org-data location stub. Default: first free port
  TEST_QUESTION_RETRIES Number of retries for transient API failures. Default: 2
  TEST_QUESTION_BACKOFF Initial retry backoff in seconds. Default: 1
EOF
}

if [[ $# -lt 2 ]]; then
  usage
  exit 1
fi

ACCOUNT_ID="$1"
shift
QUESTION="$*"

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ORG_DATA_PATH="$ROOT_DIR/org-data/$ACCOUNT_ID.json"
HOST="${AI_SERVER_HOST:-127.0.0.1}"

if [[ ! "$ACCOUNT_ID" =~ ^[0-9]+$ ]]; then
  echo "error: account id must be numeric" >&2
  exit 1
fi

if [[ ! -f "$ORG_DATA_PATH" ]]; then
  echo "error: org data not found: $ORG_DATA_PATH" >&2
  exit 1
fi

free_port() {
  python3 - <<'PY'
import socket

with socket.socket() as sock:
    sock.bind(("127.0.0.1", 0))
    print(sock.getsockname()[1])
PY
}

AI_PORT="${AI_SERVER_PORT:-$(free_port)}"
LOCATION_PORT="${LOCATION_STUB_PORT:-$(free_port)}"
LOCATION_STUB_PID=""
AI_SERVER_PID=""

cleanup() {
  if [[ -n "$AI_SERVER_PID" ]] && kill -0 "$AI_SERVER_PID" 2>/dev/null; then
    kill "$AI_SERVER_PID" 2>/dev/null || true
    wait "$AI_SERVER_PID" 2>/dev/null || true
  fi
  if [[ -n "$LOCATION_STUB_PID" ]] && kill -0 "$LOCATION_STUB_PID" 2>/dev/null; then
    kill "$LOCATION_STUB_PID" 2>/dev/null || true
    wait "$LOCATION_STUB_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT

cd "$ROOT_DIR"

python3 -u - "$ROOT_DIR" "$HOST" "$LOCATION_PORT" <<'PY' >/tmp/cdp-location-stub.log 2>&1 &
import json
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path

root = Path(sys.argv[1])
host = sys.argv[2]
port = int(sys.argv[3])


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        prefix = "/api/v1/locations/id/"
        if not self.path.startswith(prefix):
            self.send_response(404)
            self.end_headers()
            return

        org_id = self.path.removeprefix(prefix).split("?", 1)[0]
        data_path = root / "org-data" / f"{org_id}.json"
        if not data_path.exists():
            self.send_response(404)
            self.end_headers()
            return

        body = json.dumps(
            {"location": json.loads(data_path.read_text(encoding="utf-8"))}
        ).encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, format, *args):
        return


ThreadingHTTPServer((host, port), Handler).serve_forever()
PY
LOCATION_STUB_PID=$!

BACKEND_BASE_URL="http://$HOST:$LOCATION_PORT/api/v1" \
  uv run uvicorn app.main:app --host "$HOST" --port "$AI_PORT" \
  >/tmp/cdp-ai-server.log 2>&1 &
AI_SERVER_PID=$!

uv run python - "$HOST" "$AI_PORT" "$ACCOUNT_ID" "$QUESTION" "${TEST_QUESTION_RETRIES:-2}" "${TEST_QUESTION_BACKOFF:-1}" <<'PY'
import json
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path

from dotenv import dotenv_values

host, ai_port, account_id, question = sys.argv[1:5]
retries = int(sys.argv[5])
retry_backoff = float(sys.argv[6])
root = Path.cwd()
base_url = f"http://{host}:{ai_port}"

for _ in range(120):
    try:
        with urllib.request.urlopen(f"{base_url}/healthz", timeout=1) as response:
            if response.status == 200:
                break
    except Exception:
        time.sleep(0.25)
else:
    raise SystemExit("error: AI server did not become ready")

env = dotenv_values(root / ".env")
api_key = env.get("AI_SERVER_API_KEY", "")
location_data = json.loads(
    (root / "org-data" / f"{account_id}.json").read_text(encoding="utf-8")
)
payload = {
    "model": "cdp-gemini",
    "messages": [{"role": "user", "content": question}],
    "locationData": location_data,
}
headers = {"Content-Type": "application/json", "Accept": "application/json"}
if api_key:
    headers["Authorization"] = f"Bearer {api_key}"

request = urllib.request.Request(
    f"{base_url}/v1/chat/completions",
    data=json.dumps(payload).encode("utf-8"),
    headers=headers,
    method="POST",
)
for attempt in range(retries + 1):
    try:
        with urllib.request.urlopen(request, timeout=120) as response:
            body = json.loads(response.read().decode("utf-8"))
        break
    except urllib.error.HTTPError as exc:
        error_body = exc.read().decode("utf-8", errors="replace")
        if exc.code < 500 or attempt == retries:
            print(f"HTTP {exc.code}", file=sys.stderr)
            print(error_body, file=sys.stderr)
            raise SystemExit(1)
        print(
            f"Transient HTTP {exc.code}; retrying attempt {attempt + 1}/{retries}",
            file=sys.stderr,
        )
        time.sleep(retry_backoff * (2**attempt))
    except urllib.error.URLError as exc:
        if attempt == retries:
            print(f"Connection error: {exc}", file=sys.stderr)
            raise SystemExit(1)
        print(
            f"Transient connection error; retrying attempt {attempt + 1}/{retries}",
            file=sys.stderr,
        )
        time.sleep(retry_backoff * (2**attempt))

print(body["choices"][0]["message"]["content"].strip())
PY
