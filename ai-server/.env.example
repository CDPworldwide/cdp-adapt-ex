# API auth for /v1/* routes.
AI_SERVER_API_KEY=local-ai-key
AI_SERVER_API_KEY_HEADER_NAME=X-API-Key

# Public model id exposed by /v1/models and used by clients.
AI_SERVER_MODEL_NAME=cdp-gemini

# Gemini provider config for real LLM calls.
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
DEFAULT_LLM_TEMPERATURE=0.2
MAX_TOKENS=2000

# Optional public http(s) markdown URL that overrides app/prompts/system_prompt.md.
SYSTEM_PROMPT=

# Development-only mock response. Leave empty in real deployments.
# The token {location} is replaced from metadata.locationData.name.
AI_SERVER_MOCK_RESPONSE="Mock response for {location}"

# Limits.
MAX_CHAT_MESSAGES=50
MAX_CHAT_TOTAL_CHARS=50000
MAX_CHAT_RESPONSE_CHARS=20000

# CORS.
ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-API-Key
