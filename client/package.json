{
  "name": "@pac-api/client",
  "version": "1.0.0",
  "description": "TypeScript client for PAC API",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "generate": "openapi-ts && node ./scripts/patch-generated-client.mjs",
    "refresh": "./scripts/generate.sh",
    "refresh:verify": "npm run refresh && npm run build",
    "check": "./scripts/check-generated.sh",
    "verify": "npm run generate && npm run build",
    "build": "tsc",
    "clean": "rimraf dist",
    "prebuild": "npm run clean"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.92.4",
    "rimraf": "^6.1.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
